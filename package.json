{
  "name": "studio99-app-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:infra": "docker compose up -d postgres mailpit minio",
    "dev:infra:down": "docker compose down",
    "dev:infra:stripe": "docker compose --profile stripe up stripe-cli",
    "build": "next build",
    "bootstrap:project": "node scripts/bootstrap-project.mjs",
    "db:migrate": "payload migrate",
    "db:migrate:fresh": "payload migrate:fresh --forceAcceptWarning",
    "db:migrate:status": "payload migrate:status",
    "guard:override-access": "node scripts/guard-override-access.mjs",
    "jobs:run": "payload jobs:run",
    "jobs:handle-schedules": "payload jobs:handle-schedules",
    "smoke:first-run": "node scripts/smoke-first-run.mjs",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "npm run guard:override-access && eslint .",
    "lint:fix": "eslint . --fix",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "security:audit-routes": "node scripts/security-route-audit.mjs",
    "payload": "payload"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-multi-tenant": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "graphql": "^16.11.0",
    "next": "^16.2.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0",
    "stripe": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "typescript": "^5.0.0"
  }
}
