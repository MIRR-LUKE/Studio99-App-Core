# Database
# 開発ではローカル Postgres を使う。
# 本番では Supabase などの Postgres 接続文字列を入れる。
# Supabase の場合:
# - 常駐サーバー: direct connection か session pooler
# - serverless / 短命 worker: transaction pooler
# - どの場合も SSL を使う
DATABASE_URL=postgres://postgres:postgres@localhost:5432/studio99_app_core

# App / Payload
# 本番では公開 URL を入れる。招待リンクや billing の戻り先で使う。
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Auth
AUTH_USE_SESSIONS=true
AUTH_REMOVE_TOKEN_FROM_RESPONSES=true
AUTH_VERIFY_EMAIL=true
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_TIME_MS=600000
AUTH_TOKEN_EXPIRATION=7200
AUTH_FORGOT_PASSWORD_EXPIRATION_MS=3600000
# 本番では true にする。
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
# サブドメインで cookie を共有するときだけ入れる。
AUTH_COOKIE_DOMAIN=

# Mail
SMTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Studio99 <noreply@studio99.local>
MAILPIT_UI_URL=http://localhost:8025

# Storage
# local は開発用、s3 は本番向け object storage 用。
STORAGE_PROVIDER=local
S3_BUCKET=studio99-app-core
S3_REGION=ap-northeast-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=studio99
S3_SECRET_ACCESS_KEY=studio99secret
S3_FORCE_PATH_STYLE=true
MINIO_CONSOLE_URL=http://localhost:9001

# Billing
# billing を使うときだけ true にする。
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/app/billing?status=cancelled
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/app/billing?status=success
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=
STRIPE_WEBHOOK_FORWARD_TO=http://host.docker.internal:3000/api/core/billing/webhook

# Jobs
JOBS_AUTORUN=false
JOBS_AUTORUN_CRON=* * * * *
JOBS_RUN_QUEUE=default

# Security
SECURITY_CORS_ALLOWLIST=
# 現状は memory のみ。URL/TOKEN は将来の共有ストア切り替え口として予約してある。
SECURITY_RATE_LIMIT_STORE=memory
SECURITY_RATE_LIMIT_STORE_URL=
SECURITY_RATE_LIMIT_STORE_TOKEN=

# Bootstrap
# 初回の platform_owner 作成時だけ使う token。
BOOTSTRAP_OWNER_TOKEN=replace-with-a-one-time-bootstrap-token

# Observability
LOG_LEVEL=info
SERVICE_NAME=studio99-app-core

# Recovery / Retention
BACKUP_RETENTION_DAYS=30
EXPORT_RETENTION_DAYS=14
MEDIA_RETENTION_DAYS=30
RESTORE_DRILL_CADENCE_DAYS=30

# Billing defaults
BILLING_GRACE_PERIOD_DAYS=7
BILLING_DEFAULT_CURRENCY=jpy
BILLING_FALLBACK_STATUS=none
